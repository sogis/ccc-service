<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- WebSocketSession is a Spring interface and cannot be defensively copied -->
    <Match>
        <Class name="ch.so.agi.cccservice.session.SockConnection"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!-- Singletons: returning the instance is intentional -->
    <Match>
        <Class name="ch.so.agi.cccservice.security.ConnectionLimiter"/>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>
    <Match>
        <Class name="ch.so.agi.cccservice.security.ConnectionRateLimiter"/>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>

    <!-- SessionReady.method is read by Jackson via reflection -->
    <Match>
        <Class name="ch.so.agi.cccservice.message.SessionReady"/>
        <Field name="method"/>
        <Bug pattern="SS_SHOULD_BE_STATIC"/>
    </Match>
</FindBugsFilter>
